# ============================================
# TOKEN ANALYSER AGENT - ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in your keys

# Server
PORT=3001
NODE_ENV=development

# ---- Production CORS ----
# Comma-separated list of allowed frontend origins
# e.g. https://your-app.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=

# ---- CoinMarketCap API (optional, enriches futures) ----
CMC_API_KEY=

# ---- Exchange API Keys (for perps trading) ----
# Supports: binance, bybit, okx, hyperliquid
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your_exchange_api_key
EXCHANGE_SECRET=your_exchange_secret
EXCHANGE_PASSWORD=
EXCHANGE_SANDBOX=true

# ---- Solana RPC ----
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# ---- Wallets to Track (comma separated) ----
TRACKED_WALLETS=

# ---- News & Sentiment APIs ----
# CryptoPanic (free tier available: https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=

# LunarCrush (https://lunarcrush.com/developers)
LUNARCRUSH_API_KEY=

# ---- DexScreener (no key required for basic) ----
# ---- Birdeye API (Solana token data) ----
BIRDEYE_API_KEY=

# ---- Trading Parameters ----
# Max position size in USD
MAX_POSITION_SIZE=100
# Default leverage
DEFAULT_LEVERAGE=3
# Max concurrent positions
MAX_POSITIONS=5
# Stop loss percentage
STOP_LOSS_PCT=5
# Take profit percentage
TAKE_PROFIT_PCT=15
# Minimum signal confidence (0-100)
MIN_SIGNAL_CONFIDENCE=70
