{
  "name": "token-analyser-agent",
  "version": "1.0.0",
  "description": "AI Trading Agent - Perps trading, token analysis, news sentiment, wallet tracking on Solana",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build && npm run build:client",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install",
    "typecheck": "tsc --noEmit && cd client && npx tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.7.0",
    "ccxt": "^4.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "socket.io": "^4.8.0",
    "technicalindicators": "^3.1.0",
    "winston": "^3.14.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
